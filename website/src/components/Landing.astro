---
import Hero from './Hero.astro';
import Compatibility from './Compatibility.astro';
import Features from './Features.astro';
import TechStack from './TechStack.astro';
import InstallCTA from './InstallCTA.astro';
import Footer from './Footer.astro';
import DotGrid from './DotGrid.astro';
---

<div class="landing-wrapper">
  <nav class="c9-nav">
    <a href="/" class="c9-nav-logo">
      <img src="/icon.png" alt="c9watch" width="24" height="24" />
      <span>c9watch</span>
    </a>
    <div class="c9-nav-links">
      <a href="/install/">Docs</a>
      <a href="https://github.com/minchenlee/c9watch" target="_blank" rel="noopener">GitHub</a>
    </div>
  </nav>
  <div class="hero-wrapper">
    <DotGrid />
    <Hero />
  </div>
  <div class="glow-divider">
    <div class="glow-orb orb-1"></div>
  </div>
  <div class="fade-in"><Compatibility /></div>
  <div class="glow-divider">
    <div class="glow-orb orb-2"></div>
  </div>
  <div class="fade-in"><Features /></div>
  <div class="glow-divider">
    <div class="glow-orb orb-3"></div>
  </div>
  <div class="fade-in"><TechStack /></div>
  <div class="glow-divider">
    <div class="glow-orb orb-4"></div>
  </div>
  <div class="fade-in"><InstallCTA /></div>
  <Footer />
</div>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );

  document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));
</script>

<style>
  .landing-wrapper {
    margin: 0 auto;
  }

  .c9-nav {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
    padding: 0 1.5rem;
    background: var(--bg-base);
    border-bottom: 1px solid var(--border-muted);
    backdrop-filter: blur(12px);
  }

  .c9-nav-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-primary);
    font-weight: 600;
    font-size: 15px;
    text-decoration: none;
  }

  .c9-nav-logo:hover {
    text-decoration: none;
  }

  .c9-nav-logo img {
    border-radius: 6px;
  }

  .c9-nav-links {
    display: flex;
    gap: 1.5rem;
  }

  .c9-nav-links a {
    color: var(--text-secondary);
    font-size: 14px;
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .c9-nav-links a:hover {
    color: var(--text-primary);
    text-decoration: none;
  }

  .hero-wrapper {
    position: relative;
    overflow: hidden;
  }

  .glow-divider {
    position: relative;
    height: 1px;
    display: flex;
    justify-content: center;
    overflow: visible;
  }

  .glow-orb {
    position: absolute;
    top: 50%;
    border-radius: 50%;
  }

  .orb-1 {
    background: var(--accent-blue);
    width: 350px;
    height: 90px;
    filter: blur(55px);
    left: 55%;
    transform: translate(-50%, -50%);
    animation: pulse-1 6s ease-in-out infinite;
  }

  .orb-2 {
    background: var(--accent-amber);
    width: 450px;
    height: 110px;
    filter: blur(70px);
    left: 40%;
    transform: translate(-50%, -50%);
    animation: pulse-2 8s ease-in-out 1.5s infinite;
  }

  .orb-3 {
    background: var(--text-primary, #fff);
    width: 280px;
    height: 70px;
    filter: blur(50px);
    left: 60%;
    transform: translate(-50%, -50%);
    animation: pulse-3 5s ease-in-out 0.8s infinite;
  }

  .orb-4 {
    background: var(--accent-blue);
    width: 380px;
    height: 95px;
    filter: blur(65px);
    left: 45%;
    transform: translate(-50%, -50%);
    animation: pulse-4 7s ease-in-out 2.5s infinite;
  }

  @keyframes pulse-1 {
    0%, 100% { opacity: 0.12; transform: translate(-50%, -50%) scale(1); }
    40% { opacity: 0.28; transform: translate(-50%, -50%) scale(1.25); }
    70% { opacity: 0.18; transform: translate(-50%, -50%) scale(1.08); }
  }

  @keyframes pulse-2 {
    0%, 100% { opacity: 0.1; transform: translate(-50%, -50%) scale(1.05); }
    30% { opacity: 0.22; transform: translate(-50%, -50%) scale(1.1); }
    60% { opacity: 0.32; transform: translate(-50%, -50%) scale(1.3); }
    85% { opacity: 0.14; transform: translate(-50%, -50%) scale(0.95); }
  }

  @keyframes pulse-3 {
    0%, 100% { opacity: 0.05; transform: translate(-50%, -50%) scale(0.9); }
    50% { opacity: 0.14; transform: translate(-50%, -50%) scale(1.15); }
  }

  @keyframes pulse-4 {
    0%, 100% { opacity: 0.1; transform: translate(-50%, -50%) scale(1); }
    25% { opacity: 0.25; transform: translate(-50%, -50%) scale(1.2); }
    55% { opacity: 0.12; transform: translate(-50%, -50%) scale(1.05); }
    80% { opacity: 0.3; transform: translate(-50%, -50%) scale(1.15); }
  }
</style>
